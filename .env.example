# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://loreline:loreline@localhost:5432/loreline
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000

# OpenAI — server-only
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cloudflare R2 — bucket-scoped Object Read & Write token
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=loreline-books

# Public app URL / optional Google login
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
