# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://loreline:loreline@localhost:5432/loreline
REDIS_URL=redis://localhost:6379
SERVER_INTERNAL_URL=http://127.0.0.1:3001

# Better Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000

# OpenAI — server-only Realtime voice
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# OpenRouter — server-only compaction, illustrations, and book retrieval
OPENROUTER_API_KEY=
OPENROUTER_COMPACTION_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_IMAGE_MODEL=openai/gpt-image-2
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Tavily — server-only live web search for recent/outside-book facts
TAVILY_API_KEY=

# Cloudflare R2 — bucket-scoped Object Read & Write token
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=loreline-books

# Public app URL / optional Google login
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
