{
  "name": "loreline",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@loreline/web --filter=@loreline/server",
    "build": "turbo run build",
    "start": "npm run start --workspace=@loreline/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --",
    "test:e2e": "npm run test:e2e --workspace=@loreline/web",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "db:generate": "npm run db:generate --workspace=@loreline/database",
    "db:migrate": "npm run db:migrate --workspace=@loreline/database",
    "db:studio": "npm run db:studio --workspace=@loreline/database",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "docker:dev": "docker compose --profile app up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d"
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "typescript": "5.9.3"
  }
}
